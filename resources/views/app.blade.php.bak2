        <img src="{{ asset('assets/img/icons/nav-explore.svg') }}" class="vatan-nav-icon">
      </a>

      {{-- بساز --}}
      <a href="{{ route('app.create') }}" class="vatan-nav-item" data-key="create">
        <svg class="vatan-nav-icon" width="32" height="32" viewBox="0 0 24 24" fill="none">
          <path d="M12 5V19M5 12H19" stroke="currentColor" stroke-width="2.8" stroke-linecap="round"/>
        </svg>
