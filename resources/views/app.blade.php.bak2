  <style>
    * { box-sizing: border-box; }

    #vatan-nav {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 200;
      padding: 0 16px calc(env(safe-area-inset-bottom) + 28px) 16px;
    }

    #vatan-nav-bar {
      display: flex;
      align-items: center;
      height: 70px;
      background: rgba(17,17,22,0.97);
      border-radius: 999px;
      border: 1px solid #222230;
      padding: 0 6px;
      position: relative;
    }

    #vatan-nav-thumb {
      position: absolute;
      top: 6px;
      bottom: 6px;
      left: 0;
      width: 0;
      border-radius: 999px;
      background: #0BBF53;
      box-shadow: 0 0 16px rgba(11,191,83,0.4);
      z-index: 0;
      pointer-events: none;
      opacity: 0;
    }

    .vatan-nav-item {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
      text-decoration: none;
      cursor: pointer;
      position: relative;
      z-index: 1;
    }

    .vatan-nav-icon {
      width: 24px;
      height: 24px;
      display: block;
      pointer-events: none;
      filter: brightness(0) invert(1);
      opacity: 1;
    }

    .vatan-nav-item.is-active .vatan-nav-icon {
      filter: brightness(0) invert(1);
      opacity: 1;
    }

    /* light mode */
    html.light-mode #vatan-nav-bar {
      background: rgba(255,255,255,0.97);
      border-color: rgba(0,0,0,0.08);
    }
    html.light-mode .vatan-nav-icon {
      filter: brightness(0) invert(0);
    }
    html.light-mode .vatan-nav-item.is-active .vatan-nav-icon {
      filter: brightness(0) invert(1);
    }
    html.light-mode #vatan-nav-thumb {
      background: #0BBF53;
    }
  </style>
</head>
<body class="bg-[#0c0c10] text-white min-h-screen">

