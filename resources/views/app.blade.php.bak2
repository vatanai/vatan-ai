      {{-- ترندها --}}
      <a href="{{ route('app.explore') }}" class="vatan-nav-item" data-key="explore">
        <img src="{{ asset('assets/img/icons/nav-trend.svg') }}" class="vatan-nav-icon">
      </a>

      {{-- خانه (چپ‌ترین) --}}
      <a href="{{ route('app.home') }}" class="vatan-nav-item" data-key="home">
        <img src="{{ asset('assets/img/icons/nav-home.svg') }}" class="vatan-nav-icon">
      </a>

    </div>
  </nav>

  <script>
  (function () {
    var bar   = document.getElementById('vatan-nav-bar');
    var thumb = document.getElementById('vatan-nav-thumb');
    var items = Array.prototype.slice.call(document.querySelectorAll('.vatan-nav-item'));
    var path  = window.location.pathname;

    /* تشخیص صفحه فعال از URL */
    function detectKey() {
      if (path.indexOf('profile') !== -1) return 'profile';
      if (path.indexOf('ideas')   !== -1) return 'ideas';
      if (path.indexOf('create')  !== -1) return 'create';
      if (path.indexOf('explore') !== -1) return 'explore';
      if (path.indexOf('home')    !== -1) return 'home';
      return null;
    }

    /* جابجایی thumb بدون انیمیشن */
    function snapThumb(el) {
      var br  = bar.getBoundingClientRect();
      var er  = el.getBoundingClientRect();
      var pad = 6;
      thumb.style.transition = 'none';
      thumb.style.width     = (er.width - pad * 2) + 'px';
      thumb.style.transform = 'translateX(' + (er.left - br.left + pad) + 'px)';
      thumb.style.opacity   = '1';
    }

    /* جابجایی thumb با انیمیشن */
    function slideThumb(el) {
      var br  = bar.getBoundingClientRect();
      var er  = el.getBoundingClientRect();
      var pad = 6;
      thumb.style.transition = 'transform 380ms cubic-bezier(0.22,1,0.36,1), width 380ms cubic-bezier(0.22,1,0.36,1)';
      thumb.style.width     = (er.width - pad * 2) + 'px';
      thumb.style.transform = 'translateX(' + (er.left - br.left + pad) + 'px)';
      thumb.style.opacity   = '1';
    }

    function setActive(el, animated) {
      items.forEach(function (i) { i.classList.remove('is-active'); });
      el.classList.add('is-active');
      if (animated) {
        slideThumb(el);
      } else {
        snapThumb(el);
      }
    }

    /* set initial active بعد از رندر کامل */
    var activeKey = detectKey();
    if (activeKey) {
      var activeEl = bar.querySelector('[data-key="' + activeKey + '"]');
      if (activeEl) {
        /* دو requestAnimationFrame برای اطمینان از کامل شدن layout */
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            snapThumb(activeEl);
            activeEl.classList.add('is-active');
          });
        });
      }
    } else {
      thumb.style.opacity = '0';
    }

    /* کلیک روی آیتم‌ها */
    items.forEach(function (item) {
      item.addEventListener('click', function (e) {
        e.preventDefault();
        var href = item.getAttribute('href');
        setActive(item, true);
        /* navigate بعد از پایان انیمیشن */
        setTimeout(function () {
          window.location.href = href;
        }, 400);
      });
    });

  }());
  </script>

  @stack('scripts')
</body>
</html>
